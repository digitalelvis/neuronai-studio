{
  "name": "Protect main",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": true
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          {
            "context": "phpunit (PHP 8.2, Laravel 11.*)"
          },
          {
            "context": "phpunit (PHP 8.2, Laravel 12.*)"
          },
          {
            "context": "phpunit (PHP 8.3, Laravel 11.*)"
          },
          {
            "context": "phpunit (PHP 8.3, Laravel 12.*)"
          },
          {
            "context": "phpunit (PHP 8.3, Laravel 13.*)"
          },
          {
            "context": "frontend build"
          }
        ]
      }
    },
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    }
  ],
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ],
  "_comment": "actor_id 5 = RepositoryRole Administrator. User-owned repos cannot bypass via the GitHub Actions app. Release workflow must push with secrets.RELEASE_TOKEN (fine-grained PAT from an Administrator; Contents: Read and write). See docs/RELEASE.md."
}
