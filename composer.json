{
    "name": "digitalelvis/neuronai-studio",
    "description": "NeuronAI Studio — visual workflow-based AI agent builder for Laravel",
    "keywords": [
        "ai",
        "ai-agent",
        "laravel",
        "neuron",
        "workflow",
        "neuronai-studio"
    ],
    "license": "MIT",
    "homepage": "https://github.com/digitalelvis/neuronai-studio",
    "authors": [
        {
            "name": "Elvis Lopes",
            "email": "hello@digitalelvis.com"
        }
    ],
    "support": {
        "issues": "https://github.com/digitalelvis/neuronai-studio/issues",
        "source": "https://github.com/digitalelvis/neuronai-studio"
    },
    "require": {
        "php": "^8.2",
        "amphp/amp": "^3.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/view": "^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.5|^4.0",
        "neuron-core/neuron-ai": "^3.15"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "DigitalElvis\\NeuronAIStudio\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DigitalElvis\\NeuronAIStudio\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DigitalElvis\\NeuronAIStudio\\NeuronAIStudioServiceProvider"
            ],
            "aliases": {
                "NeuronAIStudio": "DigitalElvis\\NeuronAIStudio\\Facades\\NeuronAIStudio"
            }
        }
    },
    "suggest": {
        "elasticsearch/elasticsearch": "Required for the Elasticsearch knowledge-base vector store driver.",
        "opensearch-project/opensearch-php": "Required for the OpenSearch knowledge-base vector store driver.",
        "typesense/typesense-php": "Required for the Typesense knowledge-base vector store driver.",
        "neuron-core/php-vector": "Required for the PHPVector (HNSW) knowledge-base vector store driver."
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit --colors=always"
    }
}
