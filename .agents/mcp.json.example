{
  "mcpServers": {
    "99multas-telescope-prod": {
      "url": "${MCP_TELESCOPE_PROD_URL}",
      "headers": {
        "Authorization": "Bearer ${MCP_BEARER_TOKEN_PROD}"
      }
    },
    "99multas-telescope-staging": {
      "url": "${MCP_TELESCOPE_STAGING_URL}",
      "headers": {
        "Authorization": "Bearer ${MCP_BEARER_TOKEN_STAGING}"
      }
    },
    "99multas-telescope-local": {
      "command": "php",
      "args": ["/caminho/absoluto/para/99multas/artisan", "telescope-mcp:server"],
      "cwd": "/caminho/absoluto/para/99multas",
      "env": {
        "APP_ENV": "local"
      }
    }
  }
}
