{
    "name": "digitalelvis/neuronai-studio-demo",
    "description": "Demo Laravel app for neuronai-studio package",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "neuron-core/neuron-ai": "^3.15",
        "digitalelvis/neuronai-studio": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../..",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php artisan key:generate",
            "@php artisan neuronai-studio:install --no-interaction"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
